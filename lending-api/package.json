{
    "name": "@midnight-ntwrk/lending-api",
    "version": "0.1.0",
    "description": "pUSD Lending Protocol — REST API server wrapping the Midnight contract",
    "license": "Apache-2.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "node --experimental-specifier-resolution=node --loader ts-node/esm src/server.ts",
        "build": "rm -rf dist && tsc --project tsconfig.build.json",
        "start": "node dist/server.js",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@midnight-ntwrk/lending-contract": "*",
        "cors": "^2.8.5",
        "express": "^5.1.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.3"
    }
}