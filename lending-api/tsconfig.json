{
    "include": [
        "src/**/*.ts"
    ],
    "compilerOptions": {
        "outDir": "dist",
        "declaration": true,
        "lib": [
            "ESNext",
            "DOM"
        ],
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "node",
        "allowJs": true,
        "forceConsistentCasingInFileNames": true,
        "noImplicitAny": true,
        "strict": true,
        "isolatedModules": true,
        "sourceMap": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@midnight-ntwrk/lending-contract": [
                "../contract/src/index.ts"
            ]
        }
    }
}